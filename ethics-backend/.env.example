# Copy this file to .env and fill in real values before starting the server
# Then load it with: export $(cat .env | xargs)   or use dotenv package

# REQUIRED — a long random string, e.g. generated with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Optional — defaults to http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Optional — defaults to 5000
PORT=5000
